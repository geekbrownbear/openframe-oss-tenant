# Static-export (native-shell) build & runtime env
#
# TWO distinct layers:
#   1) BUILD-TIME  — read by `next build`. Set in CI/shell when producing the bundle.
#   2) RUNTIME      — NOT baked into the static bundle. Injected by the native shell
#                     (Capacitor/Tauri) into `window.process.env` BEFORE the bundle
#                     loads. runtime-config.ts already falls back to window.process.env.
#
# In the web (standalone) deploy these same NEXT_PUBLIC_* vars come from
# next-runtime-env's <PublicEnvScript /> at request time instead.

# ---- BUILD-TIME -------------------------------------------------------------
# Selects the static-export build in next.config.mjs. Omit/anything-else => standalone.
OPENFRAME_BUILD_TARGET=export

# Tenant the native shell signs into — REQUIRED for native sign-in: without it
# the unauthorized overlay rejects every attempt ("Sign-in unavailable").
# Baked at build time; can also be shell-injected like the runtime vars below.
NEXT_PUBLIC_MOBILE_TENANT_ID=<tenant-id>

# ---- RUNTIME (shell-injected window.process.env) ----------------------------
# The tenant gateway every API/WS/GraphQL/NATS/MeshCentral call must target.
# In a bundle, window.location.origin is the device (capacitor://localhost), so
# this MUST be set — there is no same-origin fallback. (migration item 5)
NEXT_PUBLIC_TENANT_HOST_URL=https://<tenant>.openframe.example

# Shared auth host (login / shared-host redirects).
NEXT_PUBLIC_SHARED_HOST_URL=https://auth.openframe.example

# Token (Bearer) auth path — cookies don't survive cross-origin from localhost.
# The shell writes of_access_token into storage (Face-ID-gated secure storage)
# and flips the dev-ticket/Bearer observer on. (migration item 6)
NEXT_PUBLIC_ENABLE_DEV_TICKET_OBSERVER=true

# Optional, mirror the standalone deploy as needed:
# NEXT_PUBLIC_APP_MODE=oss-tenant
# NEXT_PUBLIC_APP_TYPE=openframe-dashboard
# NEXT_PUBLIC_AUTH_CHECK_INTERVAL=300000
